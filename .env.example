# ===== Backend (.env in /backend) =====
NODE_ENV=development
PORT=3001

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:password@localhost:5432/lifeadmin?schema=public

# Redis (for BullMQ — use Railway/Render Redis, NOT Upstash)
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-jwt-secret-generate-with-openssl-rand-hex-64
JWT_REFRESH_SECRET=your-refresh-secret-generate-with-openssl-rand-hex-64
ACCESS_TOKEN_EXPIRY=15m
REFRESH_TOKEN_EXPIRY=30d

# Google OAuth
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# AI — Google Gemini
GEMINI_API_KEY=your-gemini-api-key

# Razorpay (India Payments)
RAZORPAY_KEY_ID=rzp_test_xxx
RAZORPAY_KEY_SECRET=your-razorpay-secret
RAZORPAY_WEBHOOK_SECRET=your-razorpay-webhook-secret

# Stripe (International Payments)
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Email (Resend)
RESEND_API_KEY=re_xxx

# Twilio (SMS/WhatsApp)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-token

# Cloudinary (File Uploads)
CLOUDINARY_URL=cloudinary://xxx

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=your-project-id
FIREBASE_PRIVATE_KEY=your-private-key
FIREBASE_CLIENT_EMAIL=your-client-email

# Frontend URL
FRONTEND_URL=http://localhost:3000

# ===== Frontend (.env.local in /apps/web) =====
NEXT_PUBLIC_API_URL=http://localhost:3001/api
NEXT_PUBLIC_RAZORPAY_KEY_ID=rzp_test_xxx
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
NEXT_PUBLIC_POSTHOG_KEY=phc_xxx
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-client-id
SENTRY_DSN=your-sentry-dsn
