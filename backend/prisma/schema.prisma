// prisma/schema.prisma
// LifeAdmin AI — Full Database Schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── USER & AUTH ─────────────────────────────────────────────

model User {
  id                String    @id @default(cuid())
  email             String    @unique
  passwordHash      String?
  name              String
  avatarUrl         String?
  phone             String?
  timezone          String    @default("Asia/Kolkata")
  locale            String    @default("en-IN")
  isEmailVerified   Boolean   @default(false)
  isPhoneVerified   Boolean   @default(false)
  onboardingDone    Boolean   @default(false)
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  // Relations
  refreshTokens     RefreshToken[]
  subscription      Subscription?
  tasks             Task[]
  habits            Habit[]
  habitLogs         HabitLog[]
  financialItems    FinancialItem[]
  goals             Goal[]
  notifications     Notification[]
  behaviorProfile   BehaviorProfile?
  familyMemberships FamilyMember[]
  familyOwned       Family?
  oauthAccounts     OAuthAccount[]
  fcmTokens         FCMToken[]
}

model OAuthAccount {
  id                String @id @default(cuid())
  userId            String
  provider          String  // "google" | "apple"
  providerAccountId String
  user              User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  deviceId  String?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── SUBSCRIPTION & PAYMENTS ─────────────────────────────────

enum PlanTier {
  FREE
  PRO
  PREMIUM
}

model Subscription {
  id                  String    @id @default(cuid())
  userId              String    @unique
  plan                PlanTier  @default(FREE)
  status              String    // "active" | "cancelled" | "past_due" | "trialing"
  currentPeriodStart  DateTime
  currentPeriodEnd    DateTime
  cancelAtPeriodEnd   Boolean   @default(false)
  razorpaySubId       String?
  stripeSubId         String?
  trialEndsAt         DateTime?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User      @relation(fields: [userId], references: [id])
  payments            Payment[]
}

model Payment {
  id              String       @id @default(cuid())
  subscriptionId  String
  amount          Float
  currency        String       @default("INR")
  status          String       // "success" | "failed" | "refunded"
  gateway         String       // "razorpay" | "stripe"
  gatewayPayId    String
  createdAt       DateTime     @default(now())
  subscription    Subscription @relation(fields: [subscriptionId], references: [id])
}

// ─── TASKS ────────────────────────────────────────────────────

enum TaskCategory {
  FINANCE
  HEALTH
  WORK
  PERSONAL
  EDUCATION
  SOCIAL
  HOME
  OTHER
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
  OVERDUE
}

model Task {
  id                String       @id @default(cuid())
  userId            String
  title             String
  description       String?
  category          TaskCategory @default(OTHER)
  priority          TaskPriority @default(MEDIUM)
  priorityScore     Float        @default(50)
  status            TaskStatus   @default(PENDING)
  dueDate           DateTime?
  completedAt       DateTime?
  isRecurring       Boolean      @default(false)
  recurrenceRule    String?
  parentTaskId      String?
  consequenceText   String?
  consequenceAmount Float?
  aiParsed          Boolean      @default(false)
  rawInput          String?
  tags              String[]
  reminderMinutes   Int[]
  snoozedUntil      DateTime?
  familyId          String?
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
  user              User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  family            Family?      @relation(fields: [familyId], references: [id])
  reminders         Reminder[]
  parentTask        Task?        @relation("TaskRecurrence", fields: [parentTaskId], references: [id])
  childTasks        Task[]       @relation("TaskRecurrence")

  @@index([userId])
  @@index([userId, status])
  @@index([userId, dueDate])
}

// ─── HABITS ───────────────────────────────────────────────────

model Habit {
  id               String       @id @default(cuid())
  userId           String
  name             String
  description      String?
  category         TaskCategory @default(HEALTH)
  frequency        String
  targetCount      Int          @default(1)
  currentStreak    Int          @default(0)
  longestStreak    Int          @default(0)
  totalCompletions Int          @default(0)
  isActive         Boolean      @default(true)
  color            String       @default("#6366f1")
  icon             String       @default("🎯")
  reminderTime     String?
  familyId         String?
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt
  user             User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  family           Family?      @relation(fields: [familyId], references: [id])
  logs             HabitLog[]

  @@index([userId])
}

model HabitLog {
  id        String   @id @default(cuid())
  habitId   String
  userId    String
  loggedAt  DateTime @default(now())
  note      String?
  habit     Habit    @relation(fields: [habitId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── FINANCE ──────────────────────────────────────────────────

enum FinanceType {
  BILL
  SUBSCRIPTION
  LOAN_EMI
  INSURANCE
  INVESTMENT
  INCOME
  CUSTOM
}

model FinancialItem {
  id                  String      @id @default(cuid())
  userId              String
  name                String
  type                FinanceType
  amount              Float
  currency            String      @default("INR")
  dueDay              Int?
  dueDate             DateTime?
  isRecurring         Boolean     @default(true)
  recurrenceRule      String?
  isAutoPay           Boolean     @default(false)
  lateFeeAmount       Float?
  lateFeeAfterDays    Int?
  reminderDaysBefore  Int[]       @default([7, 3, 1])
  notes               String?
  isPaid              Boolean     @default(false)
  lastPaidAt          DateTime?
  createdAt           DateTime    @default(now())
  user                User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── GOALS ────────────────────────────────────────────────────

model Goal {
  id              String       @id @default(cuid())
  userId          String
  title           String
  description     String?
  category        TaskCategory
  targetDate      DateTime
  progressPercent Float        @default(0)
  milestones      Json         // Array of {title, completed, date}
  aiPlan          Json?
  isActive        Boolean      @default(true)
  createdAt       DateTime     @default(now())
  user            User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// ─── NOTIFICATIONS & REMINDERS ────────────────────────────────

model Reminder {
  id          String   @id @default(cuid())
  taskId      String
  scheduledAt DateTime
  sentAt      DateTime?
  channel     String   // "push" | "email" | "sms" | "whatsapp"
  message     String
  isSent      Boolean  @default(false)
  task        Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([scheduledAt, isSent])
}

model Notification {
  id        String   @id @default(cuid())
  userId    String
  title     String
  body      String
  type      String   // "reminder" | "system" | "payment" | "insight"
  isRead    Boolean  @default(false)
  data      Json?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
}

model FCMToken {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  platform  String   // "android" | "ios" | "web"
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── AI & BEHAVIOR ────────────────────────────────────────────

model BehaviorProfile {
  id                    String   @id @default(cuid())
  userId                String   @unique
  avgCompletionRate     Float    @default(0)
  peakProductivityHour  Int      @default(10)
  weeklyCompletionMap   Json     // {Mon: 80, Tue: 60, ...}
  commonDelayPatterns   Json     // Categories user delays
  disciplineScore       Float    @default(50)
  lastAnalyzedAt        DateTime @default(now())
  user                  User     @relation(fields: [userId], references: [id])
}

// ─── FAMILY SHARING ───────────────────────────────────────────

model Family {
  id         String         @id @default(cuid())
  ownerId    String         @unique
  name       String
  inviteCode String?        @unique
  createdAt  DateTime       @default(now())
  owner      User           @relation(fields: [ownerId], references: [id])
  members    FamilyMember[]
  tasks      Task[]
  habits     Habit[]
}

model FamilyMember {
  id       String @id @default(cuid())
  familyId String
  userId   String
  role     String // "owner" | "member"
  family   Family @relation(fields: [familyId], references: [id], onDelete: Cascade)
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([familyId, userId])
}
